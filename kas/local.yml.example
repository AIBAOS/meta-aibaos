# Local mirror configuration example
# Copy this file to kas/local.yml and configure your local mirror address

# PREMIRRORS - for fetching source code
PREMIRRORS: |
  git://.*/.* http://YOUR_MIRROR_IP:PORT/downloads/
  https://.*/.* http://YOUR_MIRROR_IP:PORT/downloads/
  http://.*/.* http://YOUR_MIRROR_IP:PORT/downloads/

# SSTATE_MIRRORS - for fetching build artifacts
SSTATE_MIRRORS: |
  file://.* http://YOUR_MIRROR_IP:PORT/sstate-cache/PATH

# Replace YOUR_MIRROR_IP:PORT with your local mirror address
